APP_PORT=8080

DATABASE_PATH=/data/olt-api.db
CACHE_ENABLED=true
CACHE_TTL=60s
SCRAPER_TIMEOUT=30s
SCRAPER_MAX_WORKERS=200

LOGGING_LEVEL=info
LOGGING_FILE=/data/logs/app.log

AUTH_JWT_SECRET=replace-with-a-long-random-secret
AUTH_ACCESS_TOKEN_TTL=12h
AUTH_INITIAL_USERNAME=admin
AUTH_INITIAL_PASSWORD=change-me

VITE_API_BASE_URL=/
